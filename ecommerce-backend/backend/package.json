{
  "name": "shop_for_all",
  "version": "1.0.0",
  "description": "Multi-Tenant E-commerce SaaS",
  "homepage": "https://github.com/ishaqahnafkhan001/Shop-for-all#readme",
  "bugs": {
    "url": "https://github.com/ishaqahnafkhan001/Shop-for-all/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ishaqahnafkhan001/Shop-for-all.git"
  },
  "license": "Apache-2.0",
  "author": "ishaq",
  "type": "commonjs",
  "main": "app.js",
  "scripts": {
    "start": "node app.js",
    "test": "node --test tests/*.test.js",
    "test:integration": "node --test --test-concurrency=1 tests/integration/*.test.js",
    "test:launch": "npm test && npm run test:integration",
    "test:mongo:up": "node scripts/check-test-docker.js && docker compose -f ../../docker-compose.test-mongo.yml up -d && node scripts/wait-for-test-mongo.js",
    "test:mongo:down": "docker compose -f ../../docker-compose.test-mongo.yml down -v",
    "test:integration:local": "MONGO_URI_TEST=\"mongodb://127.0.0.1:27018/shop_for_all_launch_test?directConnection=true&replicaSet=rs0\" npm run test:integration",
    "test:launch:local": "npm test && npm run test:mongo:up && npm run test:integration:local; status=$?; npm run test:mongo:down; exit $status",
    "migrate:identity": "node scripts/migrate-accounts-memberships.js",
    "backfill:policies": "node scripts/backfillDefaultPolicies.js",
    "worker": "node workers/index.js",
    "rollup:analytics": "node scripts/runAnalyticsRollup.js"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "axios": "^1.15.1",
    "bcryptjs": "^3.0.3",
    "cloudinary": "^1.41.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^8.3.2",
    "helmet": "^8.1.0",
    "ioredis": "^5.11.1",
    "joi": "^18.1.2",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.5.0",
    "morgan": "^1.10.1",
    "multer": "^2.1.1",
    "multer-storage-cloudinary": "^4.0.0",
    "nodemailer": "^8.0.7",
    "nodemon": "^3.1.14",
    "uuid": "^14.0.0",
    "zod": "^4.3.6"
  }
}
